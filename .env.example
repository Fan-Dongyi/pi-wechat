# 是否强制重新扫码登录微信
WECHAT_FORCE_LOGIN=false

# Hermes 默认目标。当没有命中任何 match 时使用。
HERMES_DEFAULT_TARGET=default

# Hermes 请求超时，复杂子任务可以调大。
HERMES_REQUEST_TIMEOUT_MS=600000

# 每个微信会话保留最近多少轮上下文。
HERMES_HISTORY_TURNS=6

# 微信单条回复长度上限，超过后截断。
WECHAT_MAX_REPLY_CHARS=3500

# 多 Hermes 子 Agent 配置。
# baseUrl 必须带 /v1，apiKey 必须等于 Hermes API_SERVER_KEY。
# match 用于按微信消息接收者/发送者/会话 ID 路由；留空可作为默认目标。
HERMES_TARGETS='[{"id":"default","name":"Default Hermes Agent","baseUrl":"http://127.0.0.1:8642/v1","apiKey":"your-secret-key","model":"hermes-agent","match":[],"systemPrompt":"你是通过微信接入的 Hermes 子 Agent。请完成用户指令，并用简洁中文返回最终结果。"}]'
